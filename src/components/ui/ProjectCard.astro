---
interface Props {
  project: {
    data: {
      title: string;
      description: string;
      category: string;
      image: string;
      link: string;
      technologies?: string[];
    };
  };
}

const { project } = Astro.props;
const { title, description, category, image, link, technologies } = project.data;
---

<div class="project-card" data-category={category}>
  <div class="project-image">
    <img src={image} alt={title} loading="lazy" width="400" height="250">
  </div>
  <div class="project-content">
    <span class="project-category">{category}</span>
    <h3 class="project-title">{title}</h3>
    <p class="project-description">{description}</p>
    {technologies && technologies.length > 0 && (
      <div class="project-tech">
        {technologies.map((tech) => (
          <span class="neo-tag">{tech}</span>
        ))}
      </div>
    )}
    <a href={link} target="_blank" rel="noopener noreferrer" class="project-link">
      Lihat Project →
    </a>
  </div>
</div>

<style>
  .project-card {
    border: var(--border-width) solid var(--color-black);
    background: var(--color-white);
    overflow: hidden;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), border-color var(--transition-fast);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-black);
  }

  .project-card:hover {
    border-color: var(--color-blue);
    transform: translate(2px, 2px);
    box-shadow: 4px 4px 0 var(--color-black);
  }

  .project-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    border-bottom: var(--border-width) solid var(--color-black);
    background: var(--color-gray);
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-content {
    padding: var(--space-lg);
  }

  .project-category {
    display: inline-block;
    padding: 4px 10px;
    border: 2px solid var(--color-black);
    background: var(--color-blue);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .project-title {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .project-description {
    font-size: 0.9rem;
    color: var(--color-gray-dark);
    margin-bottom: var(--space-md);
    line-height: 1.5;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .project-link {
    display: inline-block;
    font-weight: 700;
    color: var(--color-blue);
    border-bottom: 3px solid var(--color-blue);
    padding-bottom: 2px;
    transition: color var(--transition-fast);
  }

  .project-link:hover {
    color: var(--color-black);
    border-color: var(--color-black);
  }
</style>
