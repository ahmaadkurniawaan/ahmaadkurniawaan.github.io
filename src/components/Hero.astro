<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    background: var(--color-white);
    position: relative;
    overflow: hidden;
    background-image: 
      linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero-image-wrapper {
    display: flex;
    justify-content: center;
    animation: fadeInUp 0.8s ease forwards;
  }

  .hero-image {
    position: relative;
    width: 320px;
    height: 400px;
  }

  .image-bg-shape {
    position: absolute;
    top: 20px;
    left: 20px;
    width: 85%;
    height: 85%;
    background: #a8edea;
    border-radius: 120px 120px 0 0;
    z-index: 0;
  }

  .hero-image img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    border: var(--border-width-thick) solid var(--color-black);
    border-radius: 0;
  }

  /* Decorative floating elements */
  .deco-badge {
    position: absolute;
    top: 15%;
    right: -30px;
    z-index: 2;
    background: #dbeafe;
    border: 3px solid var(--color-black);
    padding: 6px 14px;
    font-size: 0.8rem;
    font-weight: 700;
    border-radius: 20px;
    white-space: nowrap;
  }

  .deco-star {
    position: absolute;
    top: 40%;
    right: -20px;
    z-index: 2;
  }

  .deco-circle {
    position: absolute;
    bottom: 15%;
    left: -20px;
    z-index: 2;
    width: 50px;
    height: 50px;
    border: 4px solid var(--color-black);
    border-radius: 50%;
    background: var(--color-blue);
    clip-path: polygon(0 0, 100% 0, 100% 70%, 0 70%);
  }

  .deco-code {
    position: absolute;
    bottom: 10%;
    right: -10px;
    z-index: 2;
    background: var(--color-blue);
    color: var(--color-white);
    border: 3px solid var(--color-black);
    padding: 6px 12px;
    font-size: 0.85rem;
    font-weight: 800;
    font-family: var(--font-mono);
  }

  .hero-content {
    animation: fadeInUp 0.8s ease 0.2s forwards;
    opacity: 0;
  }

  .hero-greeting {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 900;
    color: var(--color-black);
    margin-bottom: var(--space-lg);
    line-height: 1.3;
  }

  .hero-description {
    font-size: 1.05rem;
    color: var(--color-gray-dark);
    margin-bottom: var(--space-xl);
    max-width: 560px;
    line-height: 1.8;
  }

  .hero-description strong {
    color: var(--color-black);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-actions .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 3px solid var(--color-black);
    background: var(--color-white);
    color: var(--color-black);
    transition: all var(--transition-fast);
    box-shadow: 3px 3px 0 var(--color-black);
  }

  .hero-actions .social-btn:hover {
    background: var(--color-blue);
    color: var(--color-white);
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 var(--color-black);
  }

  @media (max-width: 767px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-xl);
      padding-top: var(--space-xl);
    }

    .hero-image {
      width: 250px;
      height: 320px;
      margin: 0 auto;
    }

    .deco-badge {
      right: -10px;
      font-size: 0.7rem;
    }

    .deco-star {
      right: -10px;
    }

    .deco-code {
      right: 0;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-container {
      grid-template-columns: 1fr 1.5fr;
      gap: var(--space-xl);
    }

    .hero-image {
      width: 270px;
      height: 340px;
    }
  }
</style>
